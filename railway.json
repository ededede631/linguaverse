{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "name": "linguaverse-api",
      "install": {
        "commands": "pnpm install"
      },
      "build": {
        "commands": "pnpm run build"
      },
      "start": {
        "commands": "node api/index.js"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
